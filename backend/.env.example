# Express API Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB URI connection string
# For local MongoDB: mongodb://localhost:27017/ai_resume_analyser
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai_resume_analyser?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ai_resume_analyser

# JWT Secret for signing tokens (generate a unique random string in production)
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_random_jwt_secret_here

# URL of the AI FastAPI microservice
AI_SERVICE_URL=http://localhost:8000

# Frontend URL (for CORS in production)
CLIENT_URL=http://localhost:3000
